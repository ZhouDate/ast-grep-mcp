{
  "name": "ast-grep-mcp",
  "version": "0.1.0",
  "type": "module",
  "description": "Standalone ast-grep MCP server for AI-optimized AST code search and replace",
  "license": "MIT",
  "bin": {
    "ast-grep-mcp": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "esbuild src/cli.ts --bundle --platform=node --format=esm --outfile=dist/cli.js",
    "typecheck": "tsc --noEmit",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "@ast-grep/cli": "^0.41.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.7.0"
  }
}
